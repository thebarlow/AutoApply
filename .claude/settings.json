{
  "permissions": {
    "allow": [
      "Bash(pytest *)",
      "Bash(python -m pytest -q 2>&1)",
      "Bash(python -m pytest -v 2>&1 | tail -40)",
      "Bash(python -m pytest -q)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/commit_docsync.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/cleanup_docsync.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
