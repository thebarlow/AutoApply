{
  "manifest_version": 3,
  "name": "Indeed Saved Jobs Scraper",
  "version": "1.0.0",
  "description": "Scrapes saved jobs from Indeed and sends them to n8n for processing.",

  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://*.indeed.com/*",
    "http://localhost/*"
  ],

  "background": {
    "scripts": ["background/service_worker.js"]
  },

  "content_scripts": [
    {
      "matches": ["https://myjobs.indeed.com/*"],
      "js": ["content/saved_jobs.js"]
    },
    {
      "matches": ["https://www.indeed.com/viewjob*"],
      "js": ["content/job_detail.js"]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Indeed Saved Jobs"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "indeed-jobs-scraper@local"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
