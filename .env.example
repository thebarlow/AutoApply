DATABASE_URL=sqlite:///auto_apply.db

# LLM — the platform owns a single key server-side (no per-profile keys).
# All three resolve in core/llm.py:get_client_for_profile.
LLM_API_KEY=                       # required; key for the provider below
LLM_PROVIDER_TYPE=openrouter       # openrouter (default) | openai | anthropic | gemini
LLM_DEFAULT_MODEL=openai/gpt-4o-mini  # required; model id in the provider's format
LLM_ALLOWED_MODELS=                # comma-separated models tenants may pick for prompt slots.
                                   #   unset: production allows only LLM_DEFAULT_MODEL; local is unrestricted
                                   #   openrouter: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
                                   #   openai: gpt-4o-mini   anthropic: claude-3-5-sonnet-20241022   gemini: gemini-1.5-flash

# Resend HTTP API for admin invite emails (SMTP is blocked on Railway)
RESEND_API_KEY=          # https://resend.com/api-keys
RESEND_FROM=             # optional From, e.g. "Auto Apply <noreply@matthewbarlow.me>" (must be a Resend-verified domain)
APP_BASE_URL=https://autoapply.matthewbarlow.me

# Comma-separated allowlist of browser-extension OAuth redirect URLs.
# Chrome: https://<extension-id>.chromiumapp.org/   Firefox: browser.identity.getRedirectURL() value
EXTENSION_REDIRECT_URLS=
