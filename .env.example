DATABASE_URL=sqlite:///auto_apply.db
# LLM API keys are configured via the Config tab in the dashboard, not here.
# You can optionally pre-set them:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Zoho SMTP for admin invite emails (app-specific password if 2FA enabled)
ZOHO_SMTP_USER=          # login mailbox used for SMTP auth
ZOHO_SMTP_PASSWORD=
ZOHO_SMTP_FROM=          # optional: verified alias to send From (defaults to ZOHO_SMTP_USER)
APP_BASE_URL=https://autoapply.matthewbarlow.me

# Comma-separated allowlist of browser-extension OAuth redirect URLs.
# Chrome: https://<extension-id>.chromiumapp.org/   Firefox: browser.identity.getRedirectURL() value
EXTENSION_REDIRECT_URLS=
